# =====================================================
# Mái Nhà Xanh - .htaccess for Shared Hosting
# Phiên bản tối giản - An toàn cho mọi Shared Host
# =====================================================

# [1] Bật Rewrite Engine (bắt buộc)
RewriteEngine On

# [2] Cho phép truy cập URL không cần đuôi .php
#     Ví dụ: /phong-tro thay vì /phong-tro.php
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^([^\.]+)$ $1.php [L]

# [3] Chuyển hướng HTTP sang HTTPS (bật nếu host hỗ trợ SSL, loại trừ localhost)
RewriteCond %{HTTP_HOST} !^localhost$ [NC]
RewriteCond %{HTTP_HOST} !^127\.0\.0\.1$
RewriteCond %{HTTP:X-Forwarded-Proto} !https [NC]
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
# [4] Ép định dạng cho PWA (Sửa lỗi cho Hosting Free)
<Files "sw.php">
    AddType application/javascript .php
</Files>
<Files "manifest.json">
    AddType application/manifest+json .json
</Files>

# [5] Security Headers — Bảo mật nâng cao
<IfModule mod_headers.c>
    # Content Security Policy — Chống XSS, chỉ cho phép tài nguyên từ nguồn tin cậy
    Header set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://accounts.google.com https://cdn.onesignal.com https://cdnjs.cloudflare.com https://unpkg.com https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdnjs.cloudflare.com https://unpkg.com https://cdn.jsdelivr.net; font-src 'self' https://fonts.gstatic.com https://cdnjs.cloudflare.com; img-src 'self' data: blob: https: http:; connect-src 'self' https://api.groq.com https://generativelanguage.googleapis.com https://onesignal.com https://accounts.google.com https://*.tile.openstreetmap.org https://mt1.google.com https://fonts.googleapis.com https://fonts.gstatic.com https://unpkg.com https://cdn.jsdelivr.net https://cdn.onesignal.com https://cdnjs.cloudflare.com; frame-src 'self' https://accounts.google.com https://onesignal.com https://www.google.com; media-src 'self' blob:; object-src 'none'; base-uri 'self';"

    # Chống MIME type sniffing
    Header set X-Content-Type-Options "nosniff"

    # Chống Clickjacking
    Header set X-Frame-Options "SAMEORIGIN"

    # Referrer Policy — Giới hạn thông tin referrer gửi đi
    Header set Referrer-Policy "strict-origin-when-cross-origin"

    # Permissions Policy — Tắt các API trình duyệt không cần thiết
    Header set Permissions-Policy "camera=(), microphone=(self), geolocation=(self), payment=()"
</IfModule>

# [6] Bảo vệ file nhạy cảm — Không cho truy cập trực tiếp qua HTTP
<FilesMatch "^\.env">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</FilesMatch>

<FilesMatch "\.(md|txt|log|sql|bak)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</FilesMatch>
