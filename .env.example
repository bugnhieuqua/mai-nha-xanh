# ==========================================
# Mái Nhà Xanh — Environment Variables
# ==========================================
# Copy file này thành .env và điền giá trị thực
# KHÔNG commit file .env lên git!

# ==========================================
# Database Configuration
# ==========================================
DB_HOST=localhost
DB_NAME=quanlytro
DB_USER=root
DB_PASS=your_password_here

# ==========================================
# GroqCloud API Configuration
# ==========================================
# Lấy API Key tại: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
# ==========================================
# GroqCloud API Configuration
# ==========================================
# Lấy API Key tại: https://console.groq.com/keys
#=========================================
# OpenAI API Configuration (Optional)
# ==========================================
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# ==========================================
# Google Gemini API Configuration
# ==========================================
GEMINI_API_KEY=
## deepseek
DEEPSEEK_MODEL=deepseek-chat
# ==========================================
# Google Gemini API Configuration
# ==========================================
GEMINI_API_KEY=your_gemini_api_key_here

# ==========================================
# OneSignal Push Notification
# ==========================================
ONESIGNAL_APP_ID=your_onesignal_app_id_here
ONESIGNAL_REST_API_KEY=your_onesignal_rest_api_key_here

# ==========================================
# Application Settings
# ==========================================
# Đặt true để hiển thị lỗi chi tiết (chỉ dùng khi dev)
APP_DEBUG=false

# Bật/Tắt giới hạn tần suất gửi yêu cầu (Rate Limit). Đặt false để tắt.
ENABLE_RATE_LIMIT=true

# ==========================================
# Realtime Socket.io Server Configuration
# ==========================================
REALTIME_SERVER_URL=http://localhost:3000
